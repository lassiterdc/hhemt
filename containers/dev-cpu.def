# =============================================================================
# hhemt DEV CPU SIF (Phase-5 friction fix: local container-seam stress test).
#
# PURPOSE: a hardware-AGNOSTIC, dev-box-buildable container for stress-testing the
# container EXECUTION seams that Phase 4's tests only mock (apptainer exec wrap,
# APPTAINER_BIND, the process-prefix, `local` ThreadPoolExecutor vs `srun`
# dispatch). Runs the synth model in serial/openmp/mpi/hybrid and lets us assert
# native == container CPU bit-identity on ANY dev machine -- no GPU or cluster.
# This is NOT a cluster/reproducibility SIF: it is Kokkos-CPU (OPENMP+SERIAL), no
# CUDA/ROCm, ubuntu base by tag (the signed digest-pinned carriers are the
# frontier-rocm / uva-cuda SIFs). Closes sidecar F-FU Flag 7.
#
# Backend flags transcribed from the PROVEN native CPU build
# (_software/triton/build_tritonswmm_cpu/CMakeCache.txt): Kokkos_ENABLE_OPENMP=ON,
# Kokkos_ENABLE_SERIAL=ON, no CUDA. TRITON pin matches uva-cuda.def (15eb18a5).
# =============================================================================

Bootstrap: docker
From: ubuntu:24.04

%files
    # hhemt source tree -> uv sync --frozen for the in-container process runner.
    # Build CWD must be containers/ so `../` resolves to the hhemt repo root.
    ../  /opt/hhemt-src

%post
    set -eu
    export DEBIAN_FRONTEND=noninteractive
    apt-get update
    apt-get install -y --no-install-recommends \
        git cmake build-essential gfortran wget ca-certificates libnuma-dev python3 \
        gcc-14 g++-14 libhwloc-dev libevent-dev
    update-alternatives --install /usr/bin/gcc gcc /usr/bin/gcc-14 100
    update-alternatives --install /usr/bin/g++ g++ /usr/bin/g++-14 100

    # --- (1) OpenMPI 5.0.7 (CPU): same as uva-cuda.def MINUS --with-cuda and
    #     --with-slurm (a dev/local SIF: no GPU, no host slurm). Bundled PMIx 5.0.x,
    #     no UCX/OFI (single-node sm/self -- the mpi/hybrid dev-test topology).
    cd /tmp
    OMPI_VER=5.0.7
    wget -q https://download.open-mpi.org/release/open-mpi/v5.0/openmpi-${OMPI_VER}.tar.gz
    echo "67435fdb2560f897882e69fead171d38e7f44a6dfe1d3c90506f549a943050b8  openmpi-${OMPI_VER}.tar.gz" | sha256sum -c -
    tar xf openmpi-${OMPI_VER}.tar.gz && cd openmpi-${OMPI_VER}
    ./configure --prefix=/opt/openmpi \
        --without-ucx --without-ofi --without-hcoll \
        --enable-shared --with-prrte=internal
    make -j"$(nproc)" && make install
    cd /tmp && rm -rf openmpi-* *.tar.gz
    export PATH=/opt/openmpi/bin:${PATH}

    # --- (2) hhemt Python runtime via uv from the committed uv.lock (same as uva).
    wget -qO /tmp/uv-installer.sh https://astral.sh/uv/0.11.7/install.sh
    sh /tmp/uv-installer.sh && rm /tmp/uv-installer.sh
    export PATH=/root/.local/bin:${PATH}
    cd /opt/hhemt-src && uv sync --frozen --no-dev
    export PATH=/opt/hhemt-src/.venv/bin:/opt/openmpi/bin:${PATH}

    # --- (3) TRITON-SWMM at the SAME pinned commit as uva-cuda.def (15eb18a5), but
    #     Kokkos-CPU: ENABLE_OPENMP + ENABLE_SERIAL, NO CUDA backend / arch. The
    #     dev-test exercises run_mode serial (SERIAL), openmp/hybrid (OPENMP), and
    #     mpi (OpenMPI x SERIAL/OPENMP). Absolute mpic++/mpicc per the uva fix.
    git clone https://code.ornl.gov/hydro/triton.git /opt/triton
    cd /opt/triton && git checkout 15eb18a5d25afe5da295cb4b559a62669dbe5bc3 \
        && git submodule update --init --recursive
    mkdir -p build && cd build
    test -x /opt/openmpi/bin/mpic++ && test -x /opt/openmpi/bin/mpicc || { \
        echo "FATAL: OpenMPI wrappers missing under /opt/openmpi/bin"; ls -la /opt/openmpi/bin; exit 1; }
    cmake -DTRITON_ENABLE_SWMM=ON -DTRITON_SWMM_FLOODING_DEBUG=ON \
          -DTRITON_IGNORE_MACHINE_FILES=ON \
          -DKokkos_ENABLE_OPENMP=ON -DKokkos_ENABLE_SERIAL=ON \
          -DCMAKE_CXX_COMPILER=/opt/openmpi/bin/mpic++ \
          -DCMAKE_C_COMPILER=/opt/openmpi/bin/mpicc \
          -DCMAKE_CXX_FLAGS='-O3' \
          -DCMAKE_SKIP_INSTALL_RPATH=ON -DCMAKE_INSTALL_RPATH= \
          /opt/triton
    make -j"$(nproc)"
    test -x /opt/triton/build/triton.exe   # fail the build if the coupled exe is absent

    # --- (4) Standalone SWMM v5.2.4 (runswmm).
    git clone --branch v5.2.4 --depth 1 \
        https://github.com/USEPA/Stormwater-Management-Model.git /opt/swmm-src
    mkdir -p /opt/swmm-src/build && cd /opt/swmm-src/build
    cmake .. -DCMAKE_BUILD_TYPE=Release && make -j"$(nproc)"

    # --- (5) Install to the convention path the example profile's exe_in_sif uses.
    mkdir -p /opt/hhemt/bin
    cp /opt/triton/build/triton.exe /opt/hhemt/bin/triton.exe
    cp "$(find /opt/swmm-src/build -maxdepth 3 -type f -name runswmm -o -name swmm5 | head -1)" \
        /opt/hhemt/bin/runswmm
    chmod +x /opt/hhemt/bin/triton.exe /opt/hhemt/bin/runswmm

%environment
    export PATH=/opt/hhemt-src/.venv/bin:/opt/hhemt/bin:/opt/openmpi/bin:${PATH}
    export LD_LIBRARY_PATH=/opt/openmpi/lib:${LD_LIBRARY_PATH:-}

%labels
    org.hhemt.role        dev-cpu-container-seam-test
    org.hhemt.backend     kokkos-openmp-serial
    org.hhemt.triton_sha  15eb18a5d25afe5da295cb4b559a62669dbe5bc3
    org.hhemt.openmpi     5.0.7-pmix5
    org.hhemt.gcc         14.2.0

%runscript
    exec "$@"
